<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Para ti, Mocosa - 19 Años ❤️</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Comic Sans MS', cursive;
            background: linear-gradient(180deg, #1e3c72, #2a5298, #87CEEB);
            color: white;
            overflow-x: hidden;
            text-align: center;
        }
        
        .pantalla {
            min-height: 100vh;
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 20px;
            animation: fadeIn 1s;
        }
        
        .activa { display: flex; }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }
        
        @keyframes balanceo {
            0%, 100% { transform: rotate(-15deg); }
            50% { transform: rotate(15deg); }
        }
        
        @keyframes olas {
            0% { background-position-x: 0; }
            100% { background-position-x: 1000px; }
        }
        
        @keyframes parpadeo {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }
        
        @keyframes numeroBrilla {
            0%, 100% { text-shadow: 0 0 10px #FFD700, 0 0 20px #FFD700; }
            50% { text-shadow: 0 0 20px #FFD700, 0 0 40px #FFD700, 0 0 60px #FFD700; }
        }
        
        h1, h2 {
            text-shadow: 3px 3px 0px #000;
            margin-bottom: 20px;
        }
        
        h1 { font-size: 2rem; }
        h2 { font-size: 1.5rem; }
        
        .edad-grande {
            font-size: 5rem;
            font-weight: bold;
            color: #FFD700;
            animation: numeroBrilla 2s ease-in-out infinite;
            margin: 10px 0;
        }
        
        .btn {
            background: #ff6b6b;
            border: 4px solid #fff;
            color: white;
            padding: 15px 30px;
            font-size: 1.2rem;
            font-weight: bold;
            border-radius: 50px;
            cursor: pointer;
            box-shadow: 0 8px 0 #c44545;
            margin: 10px;
            transition: all 0.1s;
        }
        
        .btn:active {
            transform: translateY(4px);
            box-shadow: 0 4px 0 #c44545;
        }
        
        #fotoElla, .foto-amiga {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 4px solid #fff;
            object-fit: cover;
            box-shadow: 0 0 20px rgba(255,255,255,0.6);
            margin: 10px;
        }
        
        #fotoElla {
            width: 200px;
            height: 200px;
            border: 6px solid #fff;
        }
        
        .peliculas, .amigas {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            justify-content: center;
            margin: 20px 0;
        }
        
        .peliculas img {
            width: 120px;
            height: 180px;
            border-radius: 10px;
            border: 3px solid white;
            object-fit: cover;
            transform: rotate(-5deg);
            transition: 0.3s;
        }
        
        .peliculas img:active { transform: scale(1.1) rotate(0deg); }
        
        #zonaBarca {
            position: relative;
            width: 100%;
            height: 300px;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 100"><path d="M0,50 Q250,0 500,50 T1000,50 V100 H0 Z" fill="%234a90e2"/></svg>');
            background-size: 1000px 100px;
            animation: olas 3s linear infinite;
            margin: 20px 0;
        }
        
        #barca {
            width: 250px;
            position: absolute;
            bottom: 80px;
            left: 50%;
            margin-left: -125px;
            animation: balanceo 2s ease-in-out infinite;
            cursor: pointer;
        }
        
        .corazon {
            position: absolute;
            font-size: 30px;
            animation: flotar 3s ease-out forwards;
            opacity: 0;
        }
        
        @keyframes flotar {
            0% { transform: translateY(0) scale(0); opacity: 1; }
            100% { transform: translateY(-200px) scale(1.5); opacity: 0; }
        }
        
        #zonaTorta {
            position: relative;
            margin: 30px 0;
        }
        
        #torta {
            width: 200px;
            cursor: pointer;
            filter: drop-shadow(0 10px 10px rgba(0,0,0,0.3));
        }
        
        #vela {
            position: absolute;
            top: -30px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 40px;
            animation: parpadeo 1s infinite;
        }
        
        #vela.apagada {
            opacity: 0.2;
            animation: none;
        }
        
        .humo {
            position: absolute;
            top: -50px;
            left: 50%;
            font-size: 30px;
            opacity: 0;
            animation: humoSube 2s ease-out;
        }
        
        @keyframes humoSube {
            0% { opacity: 1; transform: translateX(-50%) translateY(0) scale(1); }
            100% { opacity: 0; transform: translateX(-50%) translateY(-100px) scale(2); }
        }
        
        #videoFideos {
            width: 90%;
            max-width: 400px;
            border-radius: 15px;
            border: 4px solid white;
            margin: 20px 0;
            box-shadow: 0 0 30px rgba(255,255,255,0.4);
        }
        
        #mensajeFinal {
            font-size: 1.3rem;
            line-height: 1.6;
            padding: 20px;
            background: rgba(0,0,0,0.4);
            border-radius: 20px;
            border: 3px dashed #fff;
            margin: 20px;
        }
        
        .confeti {
            position: fixed;
            width: 10px;
            height: 10px;
            top: -10px;
            z-index: 999;
        }
        
        .globo {
            position: absolute;
            font-size: 40px;
            animation: globoSube 6s ease-in infinite;
            opacity: 0.8;
        }
        
        @keyframes globoSube {
            0% { transform: translateY(100vh) rotate(0deg); }
            100% { transform: translateY(-100vh) rotate(360deg); }
        }
        
        #controlMusica {
            position: fixed;
            top: 15px;
            right: 15px;
            z-index: 1000;
            background: rgba(0,0,0,0.5);
            border: 2px solid white;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            font-size: 24px;
            cursor: pointer;
            display: none;
        }
    </style>
</head>
<body>

    <button id="controlMusica" onclick="toggleMusica()">🔊</button>

    <!-- PANTALLA 1: INICIO -->
    <div class="pantalla activa" id="pantalla1">
        <h1>Hey Mocosa 😏</h1>
        <p style="font-size: 1.2rem; margin-bottom: 10px;">Te hice algo para tus</p>
        <div class="edad-grande">19</div>
        <p style="font-size: 1.2rem; margin-bottom: 20px;">años de puro caos</p>
        <img id="fotoElla" src="FOTO_DE_ELLA.jpg" alt="La cumpleañera de 19">
        <button class="btn" onclick="siguientePantalla(2); reproducirSonido('click')">Toca aquí si ya eres legal 👀</button>
    </div>

    <!-- PANTALLA 2: PELÍCULAS -->
    <div class="pantalla" id="pantalla2">
        <h2>¿Te acuerdas de estas? 🍿</h2>
        <div class="peliculas">
            <img src="ATRAVES_DE_TU_VENTANA.jpg" alt="A través de tu ventana">
            <img src="OTRA_PELI.jpg" alt="Otra peli que vieron">
            <img src="OTRA_PELI2.jpg" alt="Otra más">
        </div>
        <p style="margin: 20px;">19 años y sigues viendo las mismas novelas 😂</p>
        <button class="btn" onclick="siguientePantalla(3); reproducirSonido('pop')">Ok ok, ¿y luego?</button>
    </div>

    <!-- PANTALLA 3: BARCA PIRATA -->
    <div class="pantalla" id="pantalla3">
        <h2>¿Y te acuerdas DÓNDE empezó todo? 🏴‍☠️</h2>
        <p style="font-size: 1.1rem; line-height: 1.6; margin: 20px;">
            En la barca pirata...<br>
            La primera vez que te vi.<br><br>
            Y después yo andaba como loco preguntándome:<br>
            <em>"¿Cómo se llama esa chica?<br>
            ¿Será de aquí de Arenillas?<br>
            Nunca la había visto...<br>
            Es demasiado hermosa" 😳</em>
        </p>
        <div id="zonaBarca">
            <img id="barca" src="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 150'><ellipse cx='100' cy='120' rx='80' ry='20' fill='%238B4513'/><rect x='90' y='40' width='20' height='80' fill='%238B4513'/><polygon points='110,40 110,80 150,60' fill='white'/><text x='60' y='125' font-size='16'>Donde te vi</text></svg>" alt="Barca Pirata">
        </div>
        <p id="contadorGritos">Suspiros desde ese día: 0</p>
        <button class="btn" onclick="gritar()">¡Toca la barca si te acuerdas! 💭</button>
        <button class="btn" id="btnBarca" style="display:none;" onclick="siguientePantalla(4)">Y aquí estamos ahora 👇</button>
    </div>

    <!-- PANTALLA 4: VIDEO FIDEOS + CUMPLEAÑOS -->
    <div class="pantalla" id="pantalla4">
        <h1>25 DE JUNIO 🎂</h1>
        <h2>¡Cumples 19 la mocosa!</h2>
        
        <div class="amigas">
            <img class="foto-amiga" src="FOTO_AMIGA1.jpg" alt="Amiga 1">
            <img class="foto-amiga" src="FOTO_AMIGA2.jpg" alt="Amiga 2">
            <img class="foto-amiga" src="FOTO_AMIGA3.jpg" alt="Amiga 3">
        </div>
        
        <p>Tú y tus cómplices del crimen 👆</p>
        
        <h2 style="margin-top: 30px;">Evidencia de sus juntas 🍜</h2>
        <video id="videoFideos" controls poster="THUMBNAIL_VIDEO.jpg">
            <source src="VIDEO_FIDEOS_IDIOMA_RARO.mp4" type="video/mp4">
            Tu navegador no soporta video 😢
        </video>
        <p style="font-size: 0.9rem; opacity: 0.8; margin-bottom: 20px;">
            ¿Qué idioma hablan? Ni ustedes saben 😂<br>
            Fideos instantáneos = cena gourmet
        </p>
        
        <div id="zonaTorta">
            <div id="vela">🕯️</div>
            <img id="torta" src="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 200'><ellipse cx='100' cy='150' rx='80' ry='30' fill='%23FF69B4'/><rect x='20' y='80' width='160' height='70' rx='10' fill='%23FFB6C1'/><rect x='30' y='50' width='140' height='40' rx='10' fill='%23FFC0CB'/><circle cx='60' cy='110' r='8' fill='red'/><circle cx='100' cy='105' r='8' fill='yellow'/><circle cx='140' cy='115' r='8' fill='blue'/><text x='85' y='125' font-size='20' font-weight='bold'>19</text></svg>" alt="Torta 19 años">
        </div>
        
        <p id="instruccionVela">¡Toca la torta 3 veces para soplar la vela! 💨</p>
        <p id="contadorSoplidos">Soplidos: 0/3</p>
        
        <div id="mensajeTorta" style="display:none; margin-top: 20px;">
            <h2 style="color: #FFD700;">¡FELIZ CUMPLEAÑOS DE 19! 🎉</h2>
            <p style="font-size: 1.1rem; margin: 15px 0;">Pide un deseo... </p>
            <p style="font-size: 0.9rem; opacity: 0.8;">Pstd: La torta me la robe, ya tienes 19 😂🥳</p>
        </div>
        
        <button class="btn" id="btnFinalCumple" style="display:none;" onclick="siguientePantalla(5); finalEpico()">Ya pedí mi deseo ✨</button>
    </div>

    <!-- PANTALLA 5: FINAL -->
    <div class="pantalla" id="pantalla5">
        <h1>Bueno ya... 19 años y sigues igual 🏆</h1>
        <div id="mensajeFinal">
            ERES MUY IMPORTANTE PARA MI MOCOSA NUNCA LO OLVIDES Y ESPERO TE HAYAS DIVERTIDO CON TODO ESTO, TE QUIERO Y SIEMPRE VOY A QUERER ESTAR PARA TI❤️
            <br><br>
            Y feliz cumpleaños de 19 adelantado 😏🎂<br>
            Que sigas comiendo fideos con tus amigas por muchos años más
            <p style="margin-top: 20px; font-size: 1rem; opacity: 0.9;">
                Desde esa barca pirata en Arenillas...<br>
                hasta tus 19 años hoy.<br>
                Y los que faltan ✨
            </p>
        </div>
        <p style="margin-top: 30px; font-size: 0.9rem;">Pstd: El último romántico? Sí. ¿Pagas la torta? También 😎</p>
        <button class="btn" onclick="location.reload()">¿Jugar otra vez?</button>
    </div>

    <!-- AUDIOS -->
    <audio id="sonidoClick" src="https://www.myinstants.com/media/sounds/click.mp3"></audio>
    <audio id="sonidoPop" src="https://www.myinstants.com/media/sounds/pop.mp3"></audio>
    <audio id="sonidoGrito" src="https://www.myinstants.com/media/sounds/wilhelm-scream.mp3"></audio>
    <audio id="sonidoCumple" src="https://www.myinstants.com/media/sounds/happy-birthday-song.mp3"></audio>
    <audio id="sonidoFinal" src="https://www.myinstants.com/media/sounds/romantic-music.mp3"></audio>
    <audio id="sonidoSoplido" src="https://www.myinstants.com/media/sounds/blow.mp3"></audio>
    <audio id="musicaFeria" loop src="https://www.soundjay.com/misc/sounds/carnival-1.mp3"></audio>

    <script>
        let gritos = 0;
        let soplidos = 0;
        let musicaActiva = false;
        
        function siguientePantalla(num) {
            document.querySelectorAll('.pantalla').forEach(p => p.classList.remove('activa'));
            document.getElementById('pantalla' + num).classList.add('activa');
            window.scrollTo(0, 0);
            
            // Música de feria en pantalla 3
            if(num === 3) {
                iniciarMusicaFeria();
            } else {
                pararMusicaFeria();
            }
            
            // Música de cumpleaños en pantalla 4
            if(num === 4) {
                reproducirSonido('cumple');
                lanzarGlobos();
            }
        }
        
        function reproducirSonido(id) {
            const audio = document.getElementById('sonido' + id.charAt(0).toUpperCase() + id.slice(1));
            if (audio) { audio.currentTime = 0; audio.play().catch(e => {}); }
        }
        
        function iniciarMusicaFeria() {
            const musica = document.getElementById('musicaFeria');
            musica.volume = 0.3;
            musica.play().catch(e => {});
            musicaActiva = true;
            document.getElementById('controlMusica').style.display = 'block';
        }
        
        function pararMusicaFeria() {
            const musica = document.getElementById('musicaFeria');
            musica.pause();
            musicaActiva = false;
            document.getElementById('controlMusica').style.display = 'none';
        }
        
        function toggleMusica() {
            const musica = document.getElementById('musicaFeria');
            const btn = document.getElementById('controlMusica');
            if (musicaActiva) {
                musica.pause();
                btn.textContent = '🔇';
                musicaActiva = false;
            } else {
                musica.play();
                btn.textContent = '🔊';
                musicaActiva = true;
            }
        }
        
        function gritar() {
            gritos++;
            document.getElementById('contadorGritos').textContent = `Suspiros desde ese día: ${gritos}`;
            reproducirSonido('grito');
            navigator.vibrate && navigator.vibrate(200);
            
            const corazon = document.createElement('div');
            corazon.className = 'corazon';
            corazon.textContent = '❤️';
            corazon.style.left = Math.random() * 80 + 10 + '%';
            corazon.style.bottom = '150px';
            document.getElementById('zonaBarca').appendChild(corazon);
            setTimeout(() => corazon.remove(), 3000);
            
            if (gritos >= 5) {
                document.getElementById('btnBarca').style.display = 'inline-block';
            }
        }
        
        document.getElementById('torta').onclick = function() {
            if (soplidos < 3) {
                soplidos++;
                document.getElementById('contadorSoplidos').textContent = `Soplidos: ${soplidos}/3`;
                reproducirSonido('soplido');
                navigator.vibrate && navigator.vibrate([100, 50, 100]);
                
                const humo = document.createElement('div');
                humo.className = 'humo';
                humo.textContent = '💨';
                document.getElementById('zonaTorta').appendChild(humo);
                setTimeout(() => humo.remove(), 2000);
                
                if (soplidos >= 3) {
                    document.getElementById('vela').classList.add('apagada');
                    document.getElementById('instruccionVela').style.display = 'none';
                    document.getElementById('mensajeTorta').style.display = 'block';
                    document.getElementById('btnFinalCumple').style.display = 'inline-block';
                    lanzarConfeti();
                }
            }
        }
        
        function lanzarGlobos() {
            for(let i = 0; i < 10; i++) {
                setTimeout(() => {
                    const globo = document.createElement('div');
                    globo.className = 'globo';
                    globo.textContent = ['🎈','🎉','🎊','✨','19'][Math.floor(Math.random()*5)];
                    globo.style.left = Math.random() * 100 + '%';
                    globo.style.animationDelay = Math.random() * 2 + 's';
                    document.getElementById('pantalla4').appendChild(globo);
                    setTimeout(() => globo.remove(), 6000);
                }, i * 300);
            }
        }
        
        function finalEpico() {
            reproducirSonido('final');
            for(let i = 0; i < 150; i++) {
                const confeti = document.createElement('div');
                confeti.className = 'confeti';
                confeti.style.background = `hsl(${Math.random() * 360}, 100%, 50%)`;
                confeti.style.left = Math.random() * 100 + '%';
                confeti.style.transform = `rotate(${Math.random() * 360}deg)`;
                document.body.appendChild(confeti);
                
                confeti.animate([
                    { transform: 'translateY(0) rotate(0deg)', opacity: 1 },
                    { transform: `translateY(${window.innerHeight + 100}px) rotate(720deg)`, opacity: 0 }
                ], {
                    duration: 3000 + Math.random() * 2000,
                    easing: 'cubic-bezier(0.25, 0.46, 0.45, 0.94)'
                }).onfinish = () => confeti.remove();
            }
        }
        
        document.getElementById('barca').onclick = gritar;
    </script>
</body>
</html>
